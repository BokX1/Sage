---
import '../styles/global.css';
import { nativeToolCount } from '../lib/nativeTools.js';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;

const nativeToolsLabel = `${nativeToolCount}+`;

const canonicalURL = new URL(Astro.url.pathname, 'https://bokx1.github.io');
const ogImage = 'https://bokx1.github.io/Sage/og-image.png';

// Enhanced JSON-LD Schema for GEO + Rich Results
const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Sage",
    "applicationCategory": "DeveloperApplication",
    "applicationSubCategory": "Agentic AI Community Engineer",
    "operatingSystem": "Docker, Node.js 22+",
    "description": `Sage is the first agentic AI community engineer — a cognitive runtime with ${nativeToolsLabel} native tools, hybrid memory (PostgreSQL + Memgraph), social graph reasoning, and zero-prompt automation for digital communities.`,
    "offers": {
      "@type": "Offer",
      "price": "0.00",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock"
    },
    "featureList": [
      `${nativeToolsLabel} native agentic tools`,
      "GraphRAG social graph with Memgraph",
      "7-stage memory pipeline",
      "OpenAI-compatible LLM API via Pollinations.ai",
      "Real-time voice analytics",
      "Agentic image generation with prompt refinement",
      "Conversational governance and configuration",
      "Channel-scoped privacy controls"
    ],
    "softwareRequirements": "Docker, PostgreSQL 15+, Node.js 22+, Memgraph",
    "url": "https://bokx1.github.io/Sage/",
    "downloadUrl": "https://github.com/BokX1/Sage",
    "license": "https://opensource.org/licenses/MIT",
    "programmingLanguage": "TypeScript"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Sage — Agentic AI Community Engineer",
    "url": "https://bokx1.github.io/Sage/",
    "description": description,
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://github.com/BokX1/Sage/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Sage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `Sage is an agentic AI community engineer — a cognitive runtime that manages Discord servers with ${nativeToolsLabel} native tools, hybrid memory (PostgreSQL + Memgraph graph database), social graph reasoning, and zero-prompt automation.`
        }
      },
      {
        "@type": "Question",
        "name": "Is Sage open source?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sage's source code is publicly available on GitHub under the MIT License."
        }
      },
      {
        "@type": "Question",
        "name": "What technologies does Sage use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sage is built with TypeScript, PostgreSQL with pgvector, Memgraph graph database, Prisma ORM, Docker, discord.js v14, GSAP, and uses an OpenAI-compatible API via Pollinations.ai — meaning it works with any OpenAI-compatible LLM provider."
        }
      }
    ]
  }
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/Sage/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL.href} />

		<!-- Robots -->
		<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

		<!-- SEO Keywords -->
		<meta name="keywords" content="agentic AI, Discord bot, community engineer, GraphRAG, cognitive runtime, social graph, hybrid memory, AI automation, Memgraph, TypeScript bot, self-hosted AI, zero-prompt automation" />
		<meta name="author" content="BokX1" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content="Sage" />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Preconnect for fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />

		<!-- JSON-LD Schemas -->
		{schemas.map(schema => (
			<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		))}

		{/* Speculation Rules API — prefetch/prerender GitHub for instant navigation */}
		<script type="speculationrules" set:html={JSON.stringify({
			prerender: [{
				urls: ["https://github.com/BokX1/Sage"],
				referrer_policy: "no-referrer"
			}],
			prefetch: [{
				urls: ["https://github.com/BokX1/Sage"],
				referrer_policy: "no-referrer"
			}]
		})} />
	</head>
	<body class="bg-[#0b0e14] text-[#E4E8EF] antialiased selection:bg-[#78b846] selection:text-[#06080d]">
		<!-- Aurora Animated Background -->
		<div class="aurora-bg" aria-hidden="true"></div>
		
		<!-- Film Grain Overlay -->
		<div class="grain-overlay" aria-hidden="true"></div>

		<!-- Vignette Depth -->
		<div class="vignette-overlay" aria-hidden="true"></div>
		
		<!-- Main Content Slot -->
		<div class="relative z-10">
			<slot />
		</div>
	</body>
</html>
