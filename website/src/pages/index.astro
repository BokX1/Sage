---
import Layout from '../layouts/Layout.astro';
import HeroDemo from '../components/HeroDemo.jsx';
import TechStackGrid from '../components/TechStackGrid.jsx';
import ToolGrid from '../components/ToolGrid.jsx';
import ShowcaseTerminal from '../components/ShowcaseTerminal.jsx';
import MemoryPipelineFlow from '../components/MemoryPipelineFlow.jsx';
import ImageRefinementDemo from '../components/ImageRefinementDemo.jsx';
import ConversationalGovernance from '../components/ConversationalGovernance.jsx';
import SovereigntyShowcase from '../components/SovereigntyShowcase.jsx';
import StatsStrip from '../components/StatsStrip.jsx';
import QuickStart from '../components/QuickStart.jsx';
import BackToTop from '../components/BackToTop.jsx';

import CommandPalette from '../components/CommandPalette.jsx';
import ConfigSimulator from '../components/ConfigSimulator.jsx';
import GraphBackground from '../components/GraphBackground.jsx';
import SocialProof from '../components/SocialProof.jsx';
import NavBar from '../components/NavBar.jsx';
import ComparisonTable from '../components/ComparisonTable.jsx';
import ScrollProgress from '../components/ScrollProgress.jsx';
import WhySage from '../components/WhySage.jsx';
import TestimonialCarousel from '../components/TestimonialCarousel.jsx';
import { nativeToolCount } from '../lib/nativeTools.js';

const nativeToolsLabel = `${nativeToolCount}+`;
---

<Layout 
 	title="Sage — The Agentic AI Teammate for Discord Communities" 
	description={`Sage is a chat-first AI teammate for Discord — ${nativeToolsLabel} native tools, layered memory, approval-aware automation, and full self-hosting. Free to use, MIT licensed.`}>
	
	<!-- Scroll Progress Indicator -->
	<ScrollProgress client:load />

	<main class="w-full min-h-screen pt-24 pb-0 overflow-hidden">
		
		<!-- Navigation Bar -->
		<NavBar client:load />

		<!-- ═══════════════════════════════════════ -->
		<!--  1. HERO SECTION                       -->
		<!-- ═══════════════════════════════════════ -->
		<section class="relative max-w-7xl mx-auto px-6 pt-20 lg:pt-32 pb-16 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center min-h-[85vh]">
			<!-- Ambient gradient mesh (behind content) -->
			<div class="absolute inset-0 overflow-hidden pointer-events-none">
				<div class="absolute top-[-20%] left-[-10%] w-[600px] h-[600px] rounded-full bg-[#78b846]/[0.04] blur-[120px]"></div>
				<div class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] rounded-full bg-[#7AA2F7]/[0.03] blur-[100px]"></div>
				<GraphBackground client:only="react" />
			</div>

			<!-- Floating Particles Layer -->
			<div class="particles-container" aria-hidden="true">
				<div class="particle" style="left: 15%; bottom: 0; animation-duration: 12s; animation-delay: 0s;"></div>
				<div class="particle" style="left: 35%; bottom: 0; animation-duration: 16s; animation-delay: 2s;"></div>
				<div class="particle" style="left: 55%; bottom: 0; animation-duration: 14s; animation-delay: 4s;"></div>
				<div class="particle" style="left: 75%; bottom: 0; animation-duration: 18s; animation-delay: 1s;"></div>
				<div class="particle" style="left: 25%; bottom: 0; animation-duration: 20s; animation-delay: 6s;"></div>
				<div class="particle" style="left: 85%; bottom: 0; animation-duration: 15s; animation-delay: 3s;"></div>
				<div class="particle" style="left: 45%; bottom: 0; animation-duration: 22s; animation-delay: 8s;"></div>
				<div class="particle" style="left: 65%; bottom: 0; animation-duration: 13s; animation-delay: 5s;"></div>
				<div class="particle" style="left: 10%; bottom: 0; animation-duration: 17s; animation-delay: 7s;"></div>
				<div class="particle" style="left: 90%; bottom: 0; animation-duration: 19s; animation-delay: 10s;"></div>
			</div>

			<div class="z-10 flex flex-col items-start text-left">
				<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#141a23] border border-[#2d4530] text-[#a9df7c] text-xs font-mono mb-6">
					<span class="w-2 h-2 rounded-full bg-[#78b846] animate-pulse"></span>
					Open Source · MIT Licensed
				</div>
				
				<h1 class="text-5xl lg:text-7xl font-extrabold tracking-tight text-white leading-[1.1] mb-6">
					Your Community's<br/>
					<span class="gradient-headline">Smartest Member</span><br/>
					<span class="shimmer-text">Just Arrived.</span>
				</h1>
				
				<p class="text-xl text-slate-400 mb-10 max-w-xl font-light leading-relaxed">
					Sage remembers every conversation, acts before you ask, and runs on <em class="text-white/80 not-italic">your</em> infrastructure. A chat-first AI teammate for Discord — no command menus, no vendor lock-in.
				</p>
				
				<div class="flex flex-wrap items-center gap-4 mb-10">
					<a href="#quickstart" class="px-8 py-4 rounded-full bg-[#78b846] text-[#050608] font-semibold hover:bg-[#a9df7c] transition-all border-glow btn-glow-pulse">
						Get Sage Free
					</a>
					<a href="https://github.com/BokX1/Sage/blob/master/docs/guides/GETTING_STARTED.md" class="px-8 py-4 rounded-full bg-transparent text-white font-medium hover:bg-white/5 border border-white/10 transition-all">
						Self-Host Guide
					</a>
					<a href="https://github.com/BokX1/Sage" target="_blank" rel="noopener noreferrer" class="px-6 py-4 rounded-full bg-white/5 text-white font-medium hover:bg-white/10 border border-white/10 transition-all inline-flex items-center gap-2">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
						Star on GitHub
					</a>
				</div>

				<!-- Social Proof Metrics -->
				<div class="flex items-center gap-8 text-sm">
					<div class="flex flex-col">
						<span class="font-bold text-white text-2xl">{nativeToolsLabel}</span>
						<span class="text-slate-500 text-xs">Autonomous Tools</span>
					</div>
					<div class="w-px h-8 bg-white/10"></div>
					<div class="flex flex-col">
						<span class="font-bold text-white text-2xl">14</span>
						<span class="text-slate-500 text-xs">Technologies</span>
					</div>
					<div class="w-px h-8 bg-white/10"></div>
					<div class="flex flex-col">
						<span class="font-bold text-white text-2xl">7</span>
						<span class="text-slate-500 text-xs">Pipeline Stages</span>
					</div>
				</div>
			</div>
			
			<!-- Interactive Product Demo -->
			<div class="relative w-full h-[500px] lg:h-[560px] rounded-3xl glass-panel overflow-hidden border border-white/5 shadow-2xl">
				<div class="absolute inset-0 bg-gradient-to-br from-[#4a7c23]/5 to-transparent z-0 pointer-events-none"></div>
				<HeroDemo client:load />
				<div class="sr-only">Interactive demo showing Sage responding to a user question in Discord, with tool calls and streaming text.</div>
			</div>
		</section>

		<!-- ═══════════════════════════════════════ -->
		<!--  EARLY PATH CHOICE                     -->
		<!-- ═══════════════════════════════════════ -->
		<div class="relative">
			<div class="absolute top-[20%] right-[-8%] w-[400px] h-[400px] rounded-full bg-[#78b846]/[0.03] blur-[100px] pointer-events-none"></div>
			<SovereigntyShowcase client:visible />
		</div>

		<!-- ── Dot Divider ── -->
		<div class="divider-dots max-w-5xl mx-auto px-6" aria-hidden="true">
			<span class="dot"></span>
			<span class="dot"></span>
			<span class="dot"></span>
		</div>

		<!-- ═══════════════════════════════════════ -->
		<!--  QUICK START                           -->
		<!-- ═══════════════════════════════════════ -->
		<QuickStart client:visible />

		<!-- ── Wave Divider ── -->
		<div class="divider-wave" aria-hidden="true">
			<svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,25 C180,50 540,5 720,35 C900,55 1080,10 1440,30 L1440,60 L0,60 Z" fill="rgba(224,175,104,0.04)"/>
				<path d="M0,40 C360,20 720,50 1080,25 C1260,15 1380,40 1440,35 L1440,60 L0,60 Z" fill="rgba(11,14,20,0.3)"/>
			</svg>
		</div>

		<!-- ═══════════════════════════════════════ -->
		<!--  SOCIAL PROOF STRIP                    -->
		<!-- ═══════════════════════════════════════ -->
		<SocialProof client:visible />

		<!-- ── Angled Divider ── -->
		<div class="divider-angle" aria-hidden="true">
			<svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,80 L0,30 Q360,0 720,20 Q1080,40 1440,10 L1440,80 Z" fill="rgba(120,184,70,0.03)"/>
				<path d="M0,80 L0,50 Q360,20 720,40 Q1080,60 1440,30 L1440,80 Z" fill="rgba(11,14,20,0.5)"/>
			</svg>
		</div>

		<!-- ═══════════════════════════════════════ -->
		<!--  WHY SAGE — Value Prop Strip            -->
		<!-- ═══════════════════════════════════════ -->
		<WhySage client:visible />

		<!-- ── Dot Divider ── -->
	<div class="divider-dots max-w-5xl mx-auto px-6" aria-hidden="true">
		<span class="dot"></span>
		<span class="dot"></span>
		<span class="dot"></span>
	</div>

	<!-- ═══════════════════════════════════════ -->
	<!--  TESTIMONIALS — Community Voices       -->
	<!-- ═══════════════════════════════════════ -->
	<TestimonialCarousel client:visible />

	<!-- ── Dot Divider ── -->
	<div class="divider-dots max-w-5xl mx-auto px-6" aria-hidden="true">
		<span class="dot" style="background: rgba(92,204,180,0.4); box-shadow: 0 0 8px rgba(92,204,180,0.3);"></span>
		<span class="dot"></span>
		<span class="dot" style="background: rgba(92,204,180,0.4); box-shadow: 0 0 8px rgba(92,204,180,0.3);"></span>
	</div>

	<!-- ═══════════════════════════════════════ -->
	<!--  STATS STRIP — Animated Counters       -->
	<!-- ═══════════════════════════════════════ -->
	<StatsStrip client:visible />

		<!-- ── Wave Divider ── -->
		<div class="divider-wave" aria-hidden="true">
			<svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,40 C240,60 480,10 720,30 C960,50 1200,15 1440,35 L1440,60 L0,60 Z" fill="rgba(122,162,247,0.04)"/>
				<path d="M0,50 C360,30 720,55 1080,35 C1260,25 1380,45 1440,40 L1440,60 L0,60 Z" fill="rgba(11,14,20,0.3)"/>
			</svg>
		</div>

		<!-- ═══════════════════════════════════════ -->
		<!--  2. TECH STACK                         -->
		<!-- ═══════════════════════════════════════ -->
		<div class="relative">
			<div class="absolute top-[20%] right-[-10%] w-[400px] h-[400px] rounded-full bg-[#BB9AF7]/[0.03] blur-[100px] pointer-events-none"></div>
			<TechStackGrid client:visible />
		</div>

		<!-- ── Angled Divider (mirrored) ── -->
		<div class="divider-angle" aria-hidden="true">
			<svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,80 L0,10 Q360,40 720,20 Q1080,0 1440,30 L1440,80 Z" fill="rgba(180,156,236,0.03)"/>
				<path d="M0,80 L0,30 Q360,60 720,40 Q1080,20 1440,50 L1440,80 Z" fill="rgba(11,14,20,0.5)"/>
			</svg>
		</div>

		<!-- ═══════════════════════════════════════ -->
		<!--  3. TOOL REGISTRY                      -->
		<!-- ═══════════════════════════════════════ -->
		<div class="relative">
			<div class="absolute bottom-[10%] left-[-5%] w-[350px] h-[350px] rounded-full bg-[#E0AF68]/[0.03] blur-[100px] pointer-events-none"></div>
			<ToolGrid client:visible />
		</div>

		<!-- ── Dot Divider ── -->
		<div class="divider-dots max-w-5xl mx-auto px-6" aria-hidden="true">
			<span class="dot" style="background: rgba(224,175,104,0.4); box-shadow: 0 0 8px rgba(224,175,104,0.3);"></span>
			<span class="dot" style="background: rgba(120,184,70,0.4); box-shadow: 0 0 8px rgba(120,184,70,0.3);"></span>
			<span class="dot" style="background: rgba(224,175,104,0.4); box-shadow: 0 0 8px rgba(224,175,104,0.3);"></span>
		</div>

		<!-- ═══════════════════════════════════════ -->
		<!--  4. LIVE AGENT TRACE                   -->
		<!-- ═══════════════════════════════════════ -->
		<div id="architecture" class="relative">
			<div class="absolute top-[30%] left-[50%] -translate-x-1/2 w-[500px] h-[500px] rounded-full bg-[#78b846]/[0.02] blur-[120px] pointer-events-none"></div>
			<ShowcaseTerminal client:visible />
		</div>

		<!-- ── Wave Divider ── -->
		<div class="divider-wave" aria-hidden="true">
			<svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,20 C180,45 360,10 540,30 C720,50 900,15 1080,35 C1260,55 1380,25 1440,30 L1440,60 L0,60 Z" fill="rgba(120,184,70,0.04)"/>
				<path d="M0,35 C240,15 480,45 720,25 C960,5 1200,45 1440,20 L1440,60 L0,60 Z" fill="rgba(11,14,20,0.3)"/>
			</svg>
		</div>

		<!-- ═══════════════════════════════════════ -->
		<!--  5. MEMORY PIPELINE                    -->
		<!-- ═══════════════════════════════════════ -->
		<div class="relative">
			<div class="absolute top-[10%] right-[-5%] w-[400px] h-[400px] rounded-full bg-[#7AA2F7]/[0.03] blur-[100px] pointer-events-none"></div>
			<MemoryPipelineFlow client:visible />
		</div>

		<!-- ── Angled Divider ── -->
		<div class="divider-angle" aria-hidden="true">
			<svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,80 L0,25 Q480,50 960,15 Q1200,0 1440,20 L1440,80 Z" fill="rgba(122,162,247,0.03)"/>
				<path d="M0,80 L0,45 Q480,70 960,35 Q1200,20 1440,40 L1440,80 Z" fill="rgba(11,14,20,0.5)"/>
			</svg>
		</div>

		<!-- ═══════════════════════════════════════ -->
		<!--  6. CREATIVE INTELLIGENCE              -->
		<!-- ═══════════════════════════════════════ -->
		<div class="relative">
			<div class="absolute bottom-[20%] left-[-5%] w-[300px] h-[300px] rounded-full bg-[#BB9AF7]/[0.04] blur-[80px] pointer-events-none"></div>
			<ImageRefinementDemo client:visible />
		</div>

		<!-- ── Wave Divider ── -->
		<div class="divider-wave" aria-hidden="true">
			<svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,30 C360,5 720,50 1080,20 C1260,8 1380,40 1440,25 L1440,60 L0,60 Z" fill="rgba(180,156,236,0.04)"/>
				<path d="M0,45 C240,25 480,50 720,30 C960,10 1200,40 1440,35 L1440,60 L0,60 Z" fill="rgba(11,14,20,0.3)"/>
			</svg>
		</div>

		<!-- ═══════════════════════════════════════ -->
		<!--  7. CONVERSATIONAL GOVERNANCE          -->
		<!-- ═══════════════════════════════════════ -->
		<ConversationalGovernance client:visible />

		<!-- ── Angled Divider ── -->
		<div class="divider-angle" aria-hidden="true">
			<svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,80 L0,20 Q360,45 720,10 Q1080,35 1440,5 L1440,80 Z" fill="rgba(224,175,104,0.03)"/>
				<path d="M0,80 L0,40 Q360,65 720,30 Q1080,55 1440,25 L1440,80 Z" fill="rgba(11,14,20,0.5)"/>
			</svg>
		</div>

		<!-- ═══════════════════════════════════════ -->
		<!--  10. CONFIGURATION PLAYGROUND          -->
		<!-- ═══════════════════════════════════════ -->
		<section class="relative max-w-7xl mx-auto px-6 py-24">
			<div class="absolute top-[50%] right-[10%] w-[400px] h-[400px] rounded-full bg-[#E0AF68]/[0.03] blur-[100px] pointer-events-none"></div>
			<div class="text-center mb-12">
				<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#141a23] border border-[#2d4530] text-[#a9df7c] text-xs font-mono mb-6">
					<span class="w-2 h-2 rounded-full bg-[#78b846]"></span>
					Deep Customization
				</div>
				<h2 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">
					Shape the <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#78b846] to-[#a9df7c]">Runtime</span>
				</h2>
				<p class="text-lg text-slate-400 max-w-2xl mx-auto font-light">
					Sage scales from a simple copilot to a fully autonomous engineer. Try toggling features below.
				</p>
			</div>
			
			<ConfigSimulator client:visible />
		</section>

		<!-- ── Wave Divider ── -->
		<div class="divider-wave" aria-hidden="true">
			<svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,25 C180,50 540,5 720,35 C900,55 1080,10 1440,30 L1440,60 L0,60 Z" fill="rgba(224,175,104,0.04)"/>
				<path d="M0,40 C360,20 720,50 1080,25 C1260,15 1380,40 1440,35 L1440,60 L0,60 Z" fill="rgba(11,14,20,0.3)"/>
			</svg>
		</div>

		<!-- ═══════════════════════════════════════ -->
		<!--  11. COMPARISON TABLE                  -->
		<!-- ═══════════════════════════════════════ -->
		<div class="relative">
			<div class="absolute top-[30%] left-[-5%] w-[400px] h-[400px] rounded-full bg-[#78b846]/[0.02] blur-[100px] pointer-events-none"></div>
			<ComparisonTable client:visible />
		</div>

		<!-- ── Angled Divider ── -->
		<div class="divider-angle" aria-hidden="true">
			<svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,80 L0,15 Q480,40 960,10 Q1200,0 1440,25 L1440,80 Z" fill="rgba(120,184,70,0.03)"/>
				<path d="M0,80 L0,35 Q480,60 960,30 Q1200,20 1440,45 L1440,80 Z" fill="rgba(11,14,20,0.5)"/>
			</svg>
		</div>

		<!-- ═══════════════════════════════════════ -->
		<!--  CTA SECTION — with Pulse Rings        -->
		<!-- ═══════════════════════════════════════ -->
		<section class="relative max-w-4xl mx-auto px-6 py-32 text-center overflow-hidden">
			<!-- Ambient glow -->
			<div class="absolute top-[30%] left-[50%] -translate-x-1/2 w-[500px] h-[500px] rounded-full bg-[#78b846]/[0.04] blur-[120px] pointer-events-none"></div>
			
			<!-- Concentric Pulse Rings -->
			<div class="absolute top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2 flex items-center justify-center pointer-events-none" aria-hidden="true">
				<div class="pulse-ring"></div>
				<div class="pulse-ring"></div>
				<div class="pulse-ring"></div>
				<div class="pulse-ring"></div>
			</div>

			<!-- Floating Particles -->
			<div class="particles-container" aria-hidden="true">
				<div class="particle" style="left: 20%; bottom: 0; animation-duration: 14s; animation-delay: 0s;"></div>
				<div class="particle" style="left: 40%; bottom: 0; animation-duration: 18s; animation-delay: 3s;"></div>
				<div class="particle" style="left: 60%; bottom: 0; animation-duration: 16s; animation-delay: 6s;"></div>
				<div class="particle" style="left: 80%; bottom: 0; animation-duration: 20s; animation-delay: 2s;"></div>
				<div class="particle" style="left: 50%; bottom: 0; animation-duration: 22s; animation-delay: 9s;"></div>
				<div class="particle" style="left: 30%; bottom: 0; animation-duration: 15s; animation-delay: 4s;"></div>
			</div>

			<h2 class="text-4xl lg:text-6xl font-extrabold text-white mb-6 relative z-10">
				Ready to <span class="gradient-headline text-glow">Get Live</span>?
			</h2>
			<p class="text-xl text-slate-400 mb-4 max-w-2xl mx-auto font-light relative z-10">
				Start free with the hosted bot in under 60 seconds. Scale to self-hosting when you're ready — zero lock-in.
			</p>
			<p class="text-sm text-slate-600 mb-10 relative z-10 font-mono">
				MIT Licensed · {nativeToolsLabel} tools · Fully open source
			</p>
			<div class="flex flex-wrap justify-center gap-4 relative z-10">
				<a href="#quickstart" class="px-10 py-5 rounded-full bg-[#78b846] text-[#050608] font-bold text-lg hover:bg-[#a9df7c] transition-all border-glow btn-glow-pulse">
					Get Sage Free
