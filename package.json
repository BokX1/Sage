{
  "name": "sage",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.10.0",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "description": "A provider-flexible Discord bot with persistent memory, tool calling, and community-aware context.",
  "main": "dist/index.js",
  "keywords": [
    "discord",
    "bot",
    "ai",
    "pollinations",
    "memory",
    "chatbot",
    "llm",
    "community"
  ],
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc -p config/tooling/tsconfig.app.json",
    "start": "node dist/index.js",
    "lint": "eslint src tests --config config/tooling/eslint.config.mjs --max-warnings 0",
    "test": "vitest run -c config/tooling/vitest.config.mjs --allowOnly=false",
    "test:trust": "ts-node -P config/tooling/tsconfig.app.json src/cli/test-trust.ts",
    "test:audit": "ts-node -P config/tooling/tsconfig.app.json src/cli/test-audit.ts",
    "social-graph:setup": "ts-node -P config/tooling/tsconfig.app.json src/cli/social-graph/setupSocialGraph.ts",
    "release:check": "npm run lint && npm run build && npm run test && npm pack",
    "onboard": "node --import tsx src/cli/onboard.ts --",
    "db:push": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force --skip-generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "doctor": "node --import tsx src/cli/doctor.ts --",
    "tools:smoke": "ts-node -P config/tooling/tsconfig.app.json src/cli/tool-smoke.ts",
    "postinstall": "prisma generate",
    "prepack": "npm run build",
    "prepare": "husky",
    "audit:prod": "npm audit --omit=dev",
    "typecheck": "tsc -p config/tooling/tsconfig.app.json --noEmit && tsc -p config/tooling/tsconfig.tests.json --noEmit",
    "docs:lint": "markdownlint-cli2 --config config/tooling/sage.markdownlint-cli2.jsonc",
    "docs:links": "node scripts/docs/check-links.cjs",
    "check:docs": "npm run docs:lint && npm run docs:links",
    "mutation:critical": "stryker run config/tooling/stryker.critical.conf.json",
    "check:mutation": "npm run mutation:critical",
    "hooks:pre-commit": "node scripts/hooks/pre-commit.cjs",
    "hooks:pre-push": "node scripts/hooks/pre-push.cjs",
    "check:local": "npm run lint && npm run typecheck && npm run test",
    "check:trust": "npm run lint && npm run typecheck && npm run test:audit && npm run test:trust",
    "check:trust:deep": "npm run check:trust && npm run check:mutation",
    "check": "npm run check:local"
  },
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "@huggingface/transformers": "^3.8.1",
    "@prisma/client": "^6.19.2",
    "@snazzah/davey": "^0.1.10",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "jsonrepair": "^3.13.2",
    "kafkajs": "^2.2.4",
    "libsodium-wrappers": "^0.8.2",
    "neo4j-driver": "^6.0.1",
    "pgvector": "^0.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prism-media": "^1.3.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.21.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "undici": "^6.23.0"
  }
}
