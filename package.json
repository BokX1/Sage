{
  "name": "sage",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.10.0",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "description": "An intelligent Discord bot with persistent memory, powered by Pollinations.ai. Remembers conversations, understands community relationships, and delivers personalized AI responses.",
  "main": "dist/index.js",
  "keywords": [
    "discord",
    "bot",
    "ai",
    "pollinations",
    "memory",
    "chatbot",
    "llm",
    "community"
  ],
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc -p config/ci/tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src tests --config config/ci/eslint.config.mjs --max-warnings 0",
    "test": "vitest run -c config/ci/vitest.config.mjs --allowOnly=false",
    "test:trust": "ts-node -P config/ci/tsconfig.json src/scripts/test-trust.ts",
    "test:audit": "ts-node -P config/ci/tsconfig.json src/scripts/test-audit.ts",
    "social-graph:setup": "ts-node -P config/ci/tsconfig.json src/social-graph/setupSocialGraph.ts",
    "release:check": "npm run lint && npm run build && npm run test && npm pack",
    "release:agentic-check": "npm run release:check && node dist/scripts/eval-gate.js",
    "onboard": "node --import tsx src/scripts/onboard.ts --",
    "db:push": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force --skip-generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "doctor": "node --import tsx src/scripts/doctor.ts --",
    "tools:smoke": "ts-node -P config/ci/tsconfig.json src/scripts/tool-smoke.ts",
    "cert": "ts-node src/scripts/cert.ts",
    "eval:run": "npm run build && node dist/scripts/eval-run.js",
    "eval:gate": "npm run build && node dist/scripts/eval-gate.js",
    "agentic:seed-replay-data": "ts-node -P config/ci/tsconfig.json src/scripts/seed-replay-traces.ts",
    "agentic:simulate": "ts-node -P config/ci/tsconfig.json src/scripts/simulate-agentic.ts",
    "agentic:tune": "npm run build && node dist/scripts/tune-agentic.js",
    "postinstall": "prisma generate",
    "prepack": "npm run build",
    "prepare": "husky",
    "audit:prod": "npm audit --omit=dev",
    "typecheck": "tsc -p config/ci/tsconfig.json --noEmit && tsc -p config/ci/tsconfig.tests.json --noEmit",
    "check:local": "npm run lint && npm run typecheck && npm run test",
    "check:trust": "npm run lint && npm run typecheck && npm run test:audit && npm run test:trust",
    "check": "npm run check:local"
  },
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "type": "commonjs",
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "@discordjs/opus": "^0.10.0",
    "@huggingface/transformers": "^3.8.1",
    "@prisma/client": "^6.19.2",
    "@snazzah/davey": "^0.1.9",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "jsonrepair": "^3.13.2",
    "kafkajs": "^2.2.4",
    "libsodium-wrappers": "^0.8.2",
    "neo4j-driver": "^6.0.1",
    "pgvector": "^0.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prism-media": "^1.3.5",
    "zod": "^4.3.6",
    "@clack/prompts": "^1.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.1",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18",
    "tsx": "^4.20.6"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "undici": "^6.23.0"
  }
}
