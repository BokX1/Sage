datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model UserProfile {
  userId             String   @id
  summary            String   @default("") // Compressed memory: preferences, stable facts
  pollinationsApiKey String? // User-provided BYOP key
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())

  // Relations
  archives UserProfileArchive[]
}

model UserProfileArchive {
  id        String   @id @default(cuid())
  userId    String
  summary   String   @db.Text
  createdAt DateTime @default(now())

  user UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, createdAt])
}

model GuildSettings {
  guildId                 String   @id
  pollinationsApiKey      String? // Guild-provided BYOP key (fallback for users)
  approvalReviewChannelId String?
  timezone                String?
  artifactVaultChannelId  String?
  modLogChannelId         String?
  updatedAt               DateTime @updatedAt
  createdAt               DateTime @default(now())
}

model GuildChannelInvokePolicy {
  id                         String   @id @default(cuid())
  guildId                    String
  channelId                  String
  mode                       String   @default("public_from_message")
  autoArchiveDurationMinutes Int?
  createdByUserId            String
  updatedByUserId            String
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@unique([guildId, channelId])
  @@index([guildId, updatedAt])
}

model HostProviderAuth {
  provider             String   @id
  encryptedAccessToken String
  encryptedRefreshToken String
  expiresAt            DateTime
  accountId            String?
  status               String
  lastErrorText        String?  @db.Text
  refreshLeaseOwner    String?
  refreshLeaseExpiresAt DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([status, updatedAt])
  @@index([refreshLeaseExpiresAt])
}

model ServerInstructions {
  guildId          String   @id
  instructionsText String   @db.Text
  version          Int      @default(1)
  updatedByAdminId String?
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model ServerInstructionsArchive {
  id               String   @id @default(cuid())
  guildId          String
  version          Int
  instructionsText String   @db.Text
  updatedByAdminId String?
  createdAt        DateTime @default(now())

  @@index([guildId, createdAt])
}

model ApprovalReviewRequest {
  id                       String   @id @default(cuid())
  threadId                 String
  originTraceId            String
  resumeTraceId            String?
  guildId                  String
  sourceChannelId          String
  reviewChannelId          String
  sourceMessageId          String?
  requesterStatusMessageId String?
  reviewerMessageId        String?
  requestedBy              String
  kind                     String
  dedupeKey                String
  executionPayloadJson     Json
  reviewSnapshotJson       Json
  interruptMetadataJson    Json?
  status                   String
  expiresAt                DateTime
  decidedBy                String?
  decidedAt                DateTime?
  executedAt               DateTime?
  resultJson               Json?
  decisionReasonText       String?  @db.Text
  errorText                String?  @db.Text
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([threadId, createdAt])
  @@index([originTraceId, createdAt])
  @@index([guildId, createdAt])
  @@index([status, expiresAt])
  @@index([reviewChannelId, createdAt])
  @@index([requestedBy, kind, dedupeKey, status, expiresAt])
}

model DiscordInteractionSession {
  id              String   @id @default(cuid())
  guildId         String
  channelId       String
  createdByUserId String
  kind            String
  payloadJson     Json
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([guildId, createdAt])
  @@index([expiresAt])
}

model AgentTaskRun {
  id                     String   @id @default(cuid())
  threadId               String   @unique
  originTraceId          String
  latestTraceId          String
  guildId                String?
  originChannelId        String
  responseChannelId      String
  requestedByUserId      String
  sourceMessageId        String?
  responseMessageId      String?
  status                 String
  waitingKind            String?
  latestDraftText        String   @db.Text
  draftRevision          Int      @default(0)
  completionKind         String?
  stopReason             String?
  nextRunnableAt         DateTime?
  leaseOwner             String?
  leaseExpiresAt         DateTime?
  heartbeatAt            DateTime?
  resumeCount            Int      @default(0)
  taskWallClockMs        Int      @default(0)
  maxTotalDurationMs     Int
  maxIdleWaitMs          Int
  lastErrorText          String?  @db.Text
  responseSessionJson    Json?
  waitingStateJson       Json?
  compactionStateJson    Json?
  checkpointMetadataJson Json?
  activeUserInterruptJson             Json?
  activeUserInterruptRevision         Int      @default(0)
  activeUserInterruptConsumedRevision Int      @default(0)
  activeUserInterruptQueuedAt         DateTime?
  activeUserInterruptConsumedAt       DateTime?
  activeUserInterruptSupersededAt     DateTime?
  activeUserInterruptSupersededRevision Int?
  startedAt              DateTime @default(now())
  completedAt            DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([originChannelId, requestedByUserId, status, updatedAt])
  @@index([responseChannelId, requestedByUserId, status, updatedAt])
  @@index([status, nextRunnableAt])
  @@index([leaseExpiresAt])
  @@index([sourceMessageId, status, updatedAt])
  @@index([waitingKind, responseChannelId, requestedByUserId, updatedAt])
}

model ChannelMessage {
  messageId         String                   @id
  guildId           String?
  channelId         String
  authorId          String
  authorDisplayName String
  authorIsBot       Boolean                  @default(false)
  timestamp         DateTime
  content           String                   @db.Text
  replyToMessageId  String?
  mentionsUserIds   Json
  mentionsBot       Boolean                  @default(false)
  embedding         ChannelMessageEmbedding?

  @@index([guildId, channelId, timestamp])
  @@index([guildId, channelId, authorIsBot, timestamp])
}

model IngestedAttachment {
  id                 String   @id @default(cuid())
  guildId            String?
  channelId          String
  messageId          String
  attachmentIndex    Int
  filename           String
  sourceUrl          String
  contentType        String?
  declaredSizeBytes  Int?
  readSizeBytes      Int?
  extractor          String?
  status             String
  errorText          String?
  extractedText      String?  @db.Text
  extractedTextChars Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([messageId, attachmentIndex])
  @@index([guildId, channelId, createdAt])
  @@index([channelId, createdAt])
  @@index([messageId])
}

model DiscordArtifact {
  id                       String   @id @default(cuid())
  guildId                  String
  originChannelId          String?
  createdByUserId          String
  name                     String
  filename                 String
  mediaKind                String
  mimeType                 String?
  descriptionText          String?  @db.Text
  latestRevisionNumber     Int      @default(0)
  latestPublishedChannelId String?
  latestPublishedMessageId String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  revisions DiscordArtifactRevision[]
  links     DiscordArtifactLink[]

  @@index([guildId, updatedAt])
  @@index([guildId, createdByUserId, updatedAt])
}

model DiscordArtifactRevision {
  id                 String   @id @default(cuid())
  artifactId         String
  revisionNumber     Int
  createdByUserId    String
  sourceKind         String
  sourceAttachmentId String?
  sourceRevisionId   String?
  format             String?
  filename           String
  mimeType           String?
  contentText        String?  @db.Text
  sizeBytes          Int?
  metadataJson       Json?
  createdAt          DateTime @default(now())

  artifact DiscordArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  links    DiscordArtifactLink[]

  @@unique([artifactId, revisionNumber])
  @@index([artifactId, createdAt])
  @@index([sourceAttachmentId])
}

model DiscordArtifactLink {
  id                String   @id @default(cuid())
  artifactId        String
  revisionId        String
  guildId           String
  channelId         String
  messageId         String
  publishedByUserId String?
  createdAt         DateTime @default(now())

  artifact DiscordArtifact         @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  revision DiscordArtifactRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)

  @@index([artifactId, createdAt])
  @@index([guildId, channelId, createdAt])
  @@index([messageId])
}

model ChannelSummary {
  id              String   @id @default(cuid())
  guildId         String
  channelId       String
  kind            String
  windowStart     DateTime
  windowEnd       DateTime
  summaryText     String
  topicsJson      Json?
  threadsJson     Json?
  unresolvedJson  Json?
  decisionsJson   Json?
  actionItemsJson Json?
  sentiment       String?
  glossaryJson    Json?
  updatedAt       DateTime @updatedAt

  @@unique([guildId, channelId, kind])
  @@index([guildId, channelId, updatedAt])
}

model AdminAudit {
  id         String   @id @default(cuid())
  guildId    String
  adminId    String
  command    String
  paramsHash String // SHA256 of normalized params JSON
  createdAt  DateTime @default(now())

  @@index([guildId, createdAt])
}

model AgentTrace {
  id                String   @id
  guildId           String?
  channelId         String
  userId            String
  routeKind         String
  threadId          String?
  parentTraceId     String?
  graphStatus       String?
  approvalRequestId String?
  terminationReason String?
  langSmithRunId    String?
  langSmithTraceId  String?
  budgetJson        Json?
  toolJson          Json?
  tokenJson         Json?
  replyText         String   @db.Text
  createdAt         DateTime @default(now())

  @@index([guildId, createdAt])
  @@index([channelId, createdAt])
  @@index([userId, createdAt])
  @@index([threadId, createdAt])
  @@index([approvalRequestId, createdAt])
  @@index([langSmithTraceId, createdAt])
}

model ModerationPolicy {
  id                String   @id @default(cuid())
  guildId           String
  name              String
  descriptionText   String?  @db.Text
  family            String
  backend           String
  ownership         String
  mode              String
  version           Int      @default(1)
  createdByUserId   String?
  updatedByUserId   String?
  externalRuleId    String?
  notifyChannelId   String?
  policySpecJson    Json
  compiledPolicyJson Json
  lastSyncedAt      DateTime?
  lastConflictText  String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  cases ModerationCase[]

  @@index([guildId, updatedAt])
  @@index([guildId, family, updatedAt])
  @@index([guildId, ownership, updatedAt])
  @@unique([guildId, name])
  @@unique([guildId, externalRuleId])
}

model ModerationCase {
  id              String   @id @default(cuid())
  guildId         String
  policyId        String?
  source          String
  status          String
  lifecycleStatus String   @default("open")
  action          String
  targetUserId    String?
  sourceMessageId String?
  channelId       String?
  reviewChannelId String?
  createdByUserId String?
  acknowledgedByUserId String?
  acknowledgedAt  DateTime?
  executedByUserId String?
  resolutionReasonText String? @db.Text
  evidenceJson    Json?
  metadataJson    Json?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  policy ModerationPolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  notes  ModerationCaseNote[]

  @@index([guildId, createdAt])
  @@index([guildId, targetUserId, createdAt])
  @@index([guildId, sourceMessageId, createdAt])
  @@index([policyId, createdAt])
  @@index([status, createdAt])
  @@index([guildId, lifecycleStatus, createdAt])
}

model ModerationCaseNote {
  id              String   @id @default(cuid())
  caseId          String
  guildId         String
  createdByUserId String
  noteText        String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  moderationCase ModerationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@index([guildId, createdAt])
}

model ScheduledTask {
  id             String   @id @default(cuid())
  guildId        String
  channelId      String
  createdByUserId String
  kind           String
  status         String
  timezone       String
  cronExpr       String?
  runAt          DateTime?
  nextRunAt      DateTime?
  skipUntil      DateTime?
  lastRunAt      DateTime?
  lastSuccessAt  DateTime?
  leaseOwner     String?
  leaseExpiresAt DateTime?
  payloadJson    Json
  provenanceJson Json?
  lastErrorText  String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  runs ScheduledTaskRun[]

  @@index([guildId, createdAt])
  @@index([guildId, status, nextRunAt])
  @@index([leaseExpiresAt])
}

model ScheduledTaskRun {
  id           String   @id @default(cuid())
  taskId       String
  dedupeKey    String
  status       String
  scheduledFor DateTime
  startedAt    DateTime?
  finishedAt   DateTime?
  errorText    String?  @db.Text
  resultJson   Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  task ScheduledTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dedupeKey])
  @@index([taskId, createdAt])
  @@index([status, scheduledFor])
}

model AttachmentChunk {
  id           String                      @id @default(cuid())
  attachmentId String
  chunkIndex   Int
  content      String                      @db.Text
  tokenCount   Int
  embedding    Unsupported("vector(256)")?
  createdAt    DateTime                    @default(now())

  @@unique([attachmentId, chunkIndex])
  @@index([attachmentId])
}

model ChannelMessageEmbedding {
  messageId String                      @id
  guildId   String?
  channelId String
  embedding Unsupported("vector(256)")?
  createdAt DateTime                    @default(now())

  message ChannelMessage @relation(fields: [messageId], references: [messageId], onDelete: Cascade)

  @@index([channelId])
  @@index([guildId, channelId])
}
