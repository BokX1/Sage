{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node10",
    "lib": [
      "ES2022"
    ],
    "types": [
      "node"
    ],
    "outDir": "../../dist",
    "rootDir": "../../src",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": "../../",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "../../src/**/*"
  ],
  "exclude": [
    "../../node_modules",
    "../../**/*.test.ts",
    "../../**/*.spec.ts"
  ]
}
