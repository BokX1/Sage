# =============================================================================
# Sage Discord Bot - Environment Configuration
# =============================================================================
# Best-practice notes:
# - Copy this file to .env and only edit values (keep keys unchanged).
# - Use plain true/false for booleans.
# - Values ending in _MS are milliseconds; _SEC are seconds; _CSV are comma-separated.
# - Never commit real credentials or tokens.
# =============================================================================

# -----------------------------------------------------------------------------
# Core / Discord Configuration (REQUIRED)
# -----------------------------------------------------------------------------
NODE_ENV=production
DISCORD_TOKEN=YOUR_DISCORD_TOKEN_HERE
DISCORD_APP_ID=YOUR_APP_ID_HERE
DATABASE_URL="postgresql://postgres:password@localhost:5432/sage?schema=public"
# If you enable Sage's autonomous moderation policies, also enable the
# Server Members Intent plus Auto Moderation Configuration and
# Auto Moderation Execution in the Discord developer portal.

# Optional disposable live Discord smoke target for `npm run langgraph:discord:smoke`.
# Use a dedicated test guild/channel because the smoke creates and deletes a role.
SAGE_DISCORD_SMOKE_GUILD_ID=
SAGE_DISCORD_SMOKE_CHANNEL_ID=
SAGE_DISCORD_SMOKE_USER_ID=
SAGE_DISCORD_SMOKE_REVIEWER_ID=

# -----------------------------------------------------------------------------
# Social Graph (Memgraph + Kafka / Redpanda)
# -----------------------------------------------------------------------------
# Memgraph (Bolt)
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# Used in Memgraph `CREATE KAFKA STREAM ... BOOTSTRAP_SERVERS ...`
# Inside docker-compose.social-graph.yml, the broker resolves as `redpanda:9092`.
MEMGRAPH_KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# Used by Sage (host) to produce events into Redpanda.
# Set empty to disable Kafka export. Default matches docker-compose.social-graph.yml.
KAFKA_BROKERS=localhost:19092
KAFKA_INTERACTIONS_TOPIC=sage.social.interactions
KAFKA_VOICE_TOPIC=sage.social.voice-sessions

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# Sage expects an OpenAI-compatible chat-completions API shape, but the provider
# itself is operator-defined. Set the required runtime agent models explicitly.
AI_PROVIDER_BASE_URL=
# Optional host-level fallback key. Leave blank to rely on the in-Discord server key flow.
AI_PROVIDER_API_KEY=
AI_PROVIDER_MAIN_AGENT_MODEL=
AI_PROVIDER_PROFILE_AGENT_MODEL=
AI_PROVIDER_SUMMARY_AGENT_MODEL=
# Optional JSON object keyed by model id for runtime budget overrides.
# Use `npm run ai-provider:probe` or `npm run doctor -- --llm-ping` to verify live Chat Completions tool-calling support against the configured provider/model.
# Example:
# AI_PROVIDER_MODEL_PROFILES_JSON={"my-main-agent-model":{"maxContextTokens":128000,"maxOutputTokens":4000,"safetyMarginTokens":512,"visionEnabled":true},"my-profile-agent-model":{"maxContextTokens":64000,"maxOutputTokens":2000,"safetyMarginTokens":256,"visionEnabled":false},"my-summary-agent-model":{"maxContextTokens":64000,"maxOutputTokens":2000,"safetyMarginTokens":256,"visionEnabled":false}}
AI_PROVIDER_MODEL_PROFILES_JSON=

# -----------------------------------------------------------------------------
# Image Provider Configuration
# -----------------------------------------------------------------------------
IMAGE_PROVIDER_BASE_URL=
IMAGE_PROVIDER_MODEL=
IMAGE_PROVIDER_API_KEY=

# -----------------------------------------------------------------------------
# Server Provider Configuration
# -----------------------------------------------------------------------------
# Used by the optional in-Discord server-key / BYOP flow.
SERVER_PROVIDER_API_KEY=
SERVER_PROVIDER_PROFILE_URL=
SERVER_PROVIDER_AUTHORIZE_URL=
SERVER_PROVIDER_DASHBOARD_URL=

# Profile memory update cadence.
PROFILE_UPDATE_INTERVAL=5

# -----------------------------------------------------------------------------
# Embedding Engine / Local Semantic Search
# -----------------------------------------------------------------------------
# Model used for local vector embeddings (RAG, archive search).
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
# Stored vector dimension (fixed for current schema: AttachmentChunk.embedding uses vector(256)).
EMBEDDING_DIMENSIONS=256

# -----------------------------------------------------------------------------
# Memory Compaction / Automated Lifecycle
# -----------------------------------------------------------------------------
# Channel LTM: Weekly compaction schedule (Sunday 23:50 UTC).
# Set to false to disable the automated weekly compaction scheduler.
LTM_COMPACTION_ENABLED=true
# User Profile: Rolling compaction interval (days).
# Profiles older than this threshold trigger a time-decay compaction pass.
USER_PROFILE_COMPACTION_INTERVAL_DAYS=30

# Encryption key for at-rest API key encryption (64 hex chars).
# If onboarding is used, this is auto-generated.
# Manual setup example: openssl rand -hex 32
SECRET_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Message Storage / Ingestion
# -----------------------------------------------------------------------------
INGESTION_ENABLED=true
INGESTION_MODE=all
INGESTION_ALLOWLIST_CHANNEL_IDS_CSV=
INGESTION_BLOCKLIST_CHANNEL_IDS_CSV=
MESSAGE_DB_STORAGE_ENABLED=true
MESSAGE_DB_MAX_MESSAGES_PER_CHANNEL=1000
PROACTIVE_POSTING_ENABLED=true
RAW_MESSAGE_TTL_DAYS=3
RING_BUFFER_MAX_MESSAGES_PER_CHANNEL=300
CONTEXT_TRANSCRIPT_MAX_MESSAGES=24

# Discord attachment ingestion
# Non-image files are extracted through Apache Tika (with safe text fallback).
FILE_INGEST_TIKA_BASE_URL=http://127.0.0.1:9998
FILE_INGEST_TIMEOUT_MS=45000
FILE_INGEST_MAX_ATTACHMENTS_PER_MESSAGE=4
FILE_INGEST_MAX_BYTES_PER_FILE=10485760
FILE_INGEST_MAX_TOTAL_BYTES_PER_MESSAGE=20971520
FILE_INGEST_OCR_ENABLED=false
# Uploaded image attachments can be cached too. Recall text is generated locally in the background.
FILE_INGEST_IMAGE_ENABLED=true
FILE_INGEST_IMAGE_MODEL_ID=onnx-community/Florence-2-large-ft
FILE_INGEST_IMAGE_TIMEOUT_MS=120000

# -----------------------------------------------------------------------------
# Channel Summaries
# -----------------------------------------------------------------------------
SUMMARY_ROLLING_WINDOW_MIN=60
SUMMARY_ROLLING_MIN_MESSAGES=20
SUMMARY_ROLLING_MIN_INTERVAL_SEC=300
SUMMARY_PROFILE_MIN_INTERVAL_SEC=21600
SUMMARY_SCHED_TICK_SEC=60

# -----------------------------------------------------------------------------
# Bot Behavior
# -----------------------------------------------------------------------------
LOG_LEVEL=info
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SEC=10
AUTOPILOT_MODE=manual
WAKE_WORDS_CSV=sage
# Optional: prefixes that can precede wake words (e.g., "hey sage")
# Leave empty to only trigger on wake word at start of message
WAKE_WORD_PREFIXES_CSV=
WAKEWORD_COOLDOWN_SEC=10
WAKEWORD_MAX_RESPONSES_PER_MIN_PER_CHANNEL=6

# -----------------------------------------------------------------------------
# Voice (Local STT)
# -----------------------------------------------------------------------------
# Uses the optional local voice-service (see config/services/self-host/docker-compose.voice.yml).
VOICE_SERVICE_BASE_URL=http://127.0.0.1:11333

# Local STT (disabled by default for privacy)
VOICE_STT_ENABLED=false
VOICE_STT_MODEL_ID=deepdml/faster-whisper-large-v3-turbo-ct2
VOICE_STT_COMPUTE_TYPE=int8
VOICE_STT_END_SILENCE_MS=900
VOICE_STT_MAX_UTTERANCE_MS=15000
VOICE_STT_MIN_UTTERANCE_MS=400

# Discord voice messages (audio attachments in text channels)
# When enabled, Sage transcribes voice messages locally via the voice service and stores the transcript in the attachment cache.
VOICE_MESSAGE_STT_ENABLED=false
VOICE_MESSAGE_STT_MAX_SECONDS=120
VOICE_MESSAGE_STT_MAX_BYTES=5000000

# Live voice context injected into chat replies (only when Sage is in your voice channel)
VOICE_LIVE_CONTEXT_LOOKBACK_SEC=180
VOICE_LIVE_CONTEXT_MAX_UTTERANCES=80

# Persist summary-only memory of voice sessions (requires STT enabled to capture content)
VOICE_SESSION_SUMMARY_ENABLED=true

# -----------------------------------------------------------------------------
# Context Budgets
# -----------------------------------------------------------------------------
# Effective input budget is managed by CONTEXT_MAX_INPUT_TOKENS and CONTEXT_RESERVED_OUTPUT_TOKENS.
# Keep CONTEXT_RESERVED_OUTPUT_TOKENS at or below CHAT_MAX_OUTPUT_TOKENS so the configured reserve matches the real chat cap.
CONTEXT_MAX_INPUT_TOKENS=180000
CONTEXT_RESERVED_OUTPUT_TOKENS=4096
CHAT_MAX_OUTPUT_TOKENS=4096

# -----------------------------------------------------------------------------
# Agentic Runtime / Tracing
# -----------------------------------------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=sage
SAGE_TRACE_DB_ENABLED=true
AGENT_WINDOW_CLOSEOUT_MAX_OUTPUT_TOKENS=2400
AGENT_WINDOW_CLOSEOUT_REQUEST_TIMEOUT_MS=20000
AGENT_RUN_SLICE_MAX_STEPS=14
AGENT_RUN_TOOL_TIMEOUT_MS=75000
AGENT_RUN_SLICE_MAX_DURATION_MS=180000
AGENT_GRAPH_MAX_OUTPUT_TOKENS=4096
AGENT_RUN_MAX_TOTAL_DURATION_MS=3600000
AGENT_RUN_MAX_IDLE_WAIT_MS=86400000
AGENT_RUN_WORKER_POLL_MS=5000
AGENT_RUN_LEASE_TTL_MS=30000
AGENT_RUN_HEARTBEAT_MS=10000
AGENT_RUN_MAX_RESUMES=256
AGENT_RUN_COMPACTION_ENABLED=true
AGENT_RUN_COMPACTION_TRIGGER_EST_TOKENS=100000
AGENT_RUN_COMPACTION_TRIGGER_ROUNDS=8
AGENT_RUN_COMPACTION_TRIGGER_TOOL_RESULTS=32
AGENT_RUN_COMPACTION_MAX_RAW_MESSAGES=32
AGENT_RUN_COMPACTION_MAX_TOOL_OBSERVATIONS=16
# Optional advanced override for LangGraph's internal hop fail-safe.
# By default Sage derives this from AGENT_RUN_SLICE_MAX_STEPS so the graph
# yields on Sage's slice budget before LangGraph's recursion guard becomes user-visible.
# Uncomment only if you need to force a custom ceiling.
# AGENT_GRAPH_RECURSION_LIMIT=
AGENT_GRAPH_MAX_TOOL_CALLS_PER_ROUND=14
AGENT_GRAPH_MAX_IDENTICAL_TOOL_BATCHES=4
AGENT_GRAPH_MAX_LOOP_GUARD_RECOVERIES=4

# -----------------------------------------------------------------------------
# Search / Tool Providers & Timeouts
# -----------------------------------------------------------------------------
TIMEOUT_CHAT_MS=180000
TIMEOUT_MEMORY_MS=600000
TOOL_WEB_SEARCH_PROVIDER_ORDER=tavily,exa,searxng
TOOL_WEB_SEARCH_TIMEOUT_MS=60000
TOOL_WEB_SEARCH_MAX_RESULTS=8
TOOL_WEB_SCRAPE_PROVIDER_ORDER=crawl4ai,firecrawl,jina,raw_fetch
TOOL_WEB_SCRAPE_TIMEOUT_MS=75000
# Provider-order presets:
# Self-host-first (recommended if local stack is running):
# TOOL_WEB_SEARCH_PROVIDER_ORDER=searxng,tavily,exa
# TOOL_WEB_SCRAPE_PROVIDER_ORDER=crawl4ai,firecrawl,jina,raw_fetch
# API-first (hosted providers first):
# TOOL_WEB_SCRAPE_PROVIDER_ORDER=firecrawl,crawl4ai,jina,raw_fetch
TAVILY_API_KEY=
EXA_API_KEY=
SEARXNG_BASE_URL=
# Host port used by config/services/self-host/docker-compose.tools.yml for SearXNG.
SEARXNG_HOST_PORT=18080
SEARXNG_SEARCH_PATH=/search
SEARXNG_CATEGORIES=general
SEARXNG_LANGUAGE=en-US
CRAWL4AI_BASE_URL=
CRAWL4AI_BEARER_TOKEN=
JINA_READER_BASE_URL=https://r.jina.ai/http://

# -----------------------------------------------------------------------------
# MCP Presets And Extra Servers
# -----------------------------------------------------------------------------
# Enable curated MCP presets by id (comma-separated).
# Supported starter presets: github,context7,playwright,firecrawl,markitdown
MCP_PRESETS_ENABLED_CSV=

# Optional JSON array of extra MCP server definitions. Supports stdio and
# streamable HTTP transports with ${ENV_VAR} placeholder interpolation.
# Example:
# MCP_EXTRA_SERVERS_JSON=[{"id":"linear","enabled":true,"trustLevel":"untrusted","transport":{"kind":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-linear"]},"allow":{"tools":["search_issues"]}}]
MCP_EXTRA_SERVERS_JSON=

# GitHub preset
MCP_PRESET_GITHUB_TRANSPORT=streamable_http
# Stdio example: npx -y github/github-mcp-server stdio --read-only
MCP_PRESET_GITHUB_COMMAND=
MCP_PRESET_GITHUB_ARGS_JSON=["stdio","--read-only"]
MCP_PRESET_GITHUB_URL=https://api.githubcopilot.com/mcp/
MCP_PRESET_GITHUB_TOKEN=
MCP_PRESET_GITHUB_TOOLSETS_CSV=context,repos,issues,pull_requests,users

# Context7 preset
MCP_PRESET_CONTEXT7_TRANSPORT=stdio
MCP_PRESET_CONTEXT7_COMMAND=
MCP_PRESET_CONTEXT7_ARGS_JSON=["-y","@upstash/context7-mcp"]
MCP_PRESET_CONTEXT7_URL=
MCP_PRESET_CONTEXT7_TOKEN=

# Playwright preset
MCP_PRESET_PLAYWRIGHT_TRANSPORT=stdio
MCP_PRESET_PLAYWRIGHT_COMMAND=
MCP_PRESET_PLAYWRIGHT_ARGS_JSON=["@playwright/mcp@latest"]
MCP_PRESET_PLAYWRIGHT_URL=
MCP_PRESET_PLAYWRIGHT_TOKEN=

# Firecrawl preset
MCP_PRESET_FIRECRAWL_TRANSPORT=streamable_http
MCP_PRESET_FIRECRAWL_COMMAND=
MCP_PRESET_FIRECRAWL_ARGS_JSON=[]
MCP_PRESET_FIRECRAWL_URL=https://mcp.firecrawl.dev/mcp
MCP_PRESET_FIRECRAWL_TOKEN=

# MarkItDown preset
MCP_PRESET_MARKITDOWN_TRANSPORT=stdio
MCP_PRESET_MARKITDOWN_COMMAND=
MCP_PRESET_MARKITDOWN_ARGS_JSON=["markitdown-mcp"]
MCP_PRESET_MARKITDOWN_URL=
MCP_PRESET_MARKITDOWN_TOKEN=

# -----------------------------------------------------------------------------
# Doctor Utility
# -----------------------------------------------------------------------------
# Set to 1 to enable live AI provider ping plus Chat Completions tool-calling probe checks in npm run doctor
# One-off cross-platform alternative: npm run doctor -- --llm-ping
LLM_DOCTOR_PING=0
